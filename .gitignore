# See https://www.dartlang.org/guides/libraries/private-files

# Files and directories created by pub
.dart_tool/
.packages
build/
# Pub workspace: commit root pubspec.lock for reproducible CI.
# (packages/*/pubspec.lock are not generated under workspaces.)
# pubspec.lock

# Directory created by dartdoc
# If you don't generate documentation locally you can remove this line.
doc/api/

# dotenv environment variables file
.env*

# Avoid committing generated Javascript files:
*.dart.js
# Produced by the --dump-info flag.
*.info.json
# When generated by dart2js. Don't specify *.js if your
# project includes source files written in JavaScript.
*.js
*.js_
*.js.deps
*.js.map

.flutter-plugins
.flutter-plugins-dependencies

# Coverage output (generated by tool/run_tests.sh and CI).
coverage/
*.lcov

# pana
pana_report.json

# Claude Code sandbox config (developer-local).
.claude/

# Terraform local artifacts (state / secrets — never commit).
validation/
tf-out/
*.tfstate
*.tfstate.backup
*.tfvars
.terraform/
.terraform.lock.hcl

# Internal docs — kept local only.
docs/
RESUME.md

# sed -i.bak residue (tool/prepare_publish.sh generates these during swap).
*.bak