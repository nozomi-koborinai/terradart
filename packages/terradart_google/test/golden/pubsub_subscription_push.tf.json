{
  "terraform": {
    "required_version": ">= 1.11.0",
    "required_providers": {
      "google": {
        "source": "hashicorp/google",
        "version": "~> 7.0"
      }
    }
  },
  "provider": {
    "google": {
      "project": "demo"
    }
  },
  "resource": {
    "google_pubsub_topic": {
      "orders": {
        "name": "orders-prod"
      }
    },
    "google_pubsub_subscription": {
      "orders_push": {
        "name": "orders-push",
        "topic": "${google_pubsub_topic.orders.id}",
        "push_config": {
          "push_endpoint": "https://app.example.com/push",
          "attributes": {
            "x-goog-version": "v1"
          }
        }
      }
    }
  }
}
