{
  "terraform": {
    "required_version": ">= 1.11.0",
    "required_providers": {
      "google": {
        "source": "hashicorp/google",
        "version": "~> 7.0"
      }
    }
  },
  "provider": {
    "google": {
      "project": "demo"
    }
  },
  "resource": {
    "google_pubsub_topic": {
      "orders": {
        "name": "orders",
        "message_retention_duration": "604800s"
      }
    },
    "google_pubsub_subscription": {
      "orders_push": {
        "name": "orders-push",
        "topic": "${google_pubsub_topic.orders.id}",
        "push_config": {
          "push_endpoint": "https://app.example.com/push"
        }
      }
    },
    "google_pubsub_topic_iam_member": {
      "orders_publisher": {
        "topic": "${google_pubsub_topic.orders.name}",
        "role": "roles/pubsub.publisher",
        "member": "serviceAccount:pub@demo.iam.gserviceaccount.com"
      }
    },
    "google_pubsub_subscription_iam_member": {
      "orders_consumer": {
        "subscription": "${google_pubsub_subscription.orders_push.name}",
        "role": "roles/pubsub.subscriber",
        "member": "serviceAccount:sub@demo.iam.gserviceaccount.com"
      }
    },
    "google_cloud_tasks_queue": {
      "jobs": {
        "name": "jobs",
        "location": "us-central1"
      }
    },
    "google_cloud_tasks_queue_iam_member": {
      "jobs_enqueuer": {
        "name": "${google_cloud_tasks_queue.jobs.name}",
        "location": "${google_cloud_tasks_queue.jobs.location}",
        "role": "roles/cloudtasks.enqueuer",
        "member": "serviceAccount:enq@demo.iam.gserviceaccount.com"
      }
    },
    "google_secret_manager_secret": {
      "api_key": {
        "secret_id": "orders-api-key",
        "replication": {
          "auto": {}
        }
      }
    },
    "google_secret_manager_secret_version": {
      "api_key_v1": {
        "secret": "${google_secret_manager_secret.api_key.id}",
        "secret_data_wo": "REPLACE_ME",
        "secret_data_wo_version": 1
      }
    },
    "google_secret_manager_secret_iam_member": {
      "api_key_reader": {
        "secret_id": "${google_secret_manager_secret.api_key.secret_id}",
        "role": "roles/secretmanager.secretAccessor",
        "member": "serviceAccount:app@demo.iam.gserviceaccount.com"
      }
    },
    "google_cloud_scheduler_job": {
      "nightly": {
        "name": "nightly",
        "region": "us-central1",
        "schedule": "0 0 * * *",
        "pubsub_target": {
          "topic_name": "${google_pubsub_topic.orders.id}"
        }
      }
    }
  },
  "data": {
    "google_project": {
      "current": {}
    }
  }
}
